#!/usr/bin/env php
<?php
/**
 * oasis/http v3 Migration Pre-Check Script
 *
 * Scans a target directory for references to removed/changed APIs from the
 * oasis/http v2 → v3 upgrade (PHP 8.5 migration, Silex → Symfony MicroKernel).
 *
 * Usage: oasis-http-migrate-v3-check [options] <directory>
 *
 * Options:
 *   --help          Show usage information
 *   --format=FORMAT Output format: text (default), json
 *
 * Exit codes:
 *   0  No 🔴 findings (or no findings at all)
 *   1  At least one 🔴 finding exists
 *   2  Input error (directory not found, invalid arguments, etc.)
 */

// Conditional guard: only execute main() when run as CLI script.
// This allows test files to require this file and call individual functions
// without triggering main() execution.
if (PHP_SAPI === 'cli' && isset($argv) && realpath($argv[0]) === realpath(__FILE__)) {
    exit(main($argv));
}

// ============================================================
// 1. Rule Registry
// ============================================================

