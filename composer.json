{
    "name"             : "oasis/http",
    "description"      : "A Symfony MicroKernel-based HTTP framework for routing, middleware, security, and more.",
    "minimum-stability": "stable",
    "license"          : "MIT",
    "authors"          : [
        {
            "name" : "Minhao Zhang",
            "email": "minhao.zhang@qq.com"
        }
    ],
    "require"          : {
        "php"                           : ">=8.5",
        "symfony/http-foundation"       : "^7.2",
        "symfony/http-kernel"           : "^7.2",
        "symfony/dependency-injection"  : "^7.2",
        "symfony/event-dispatcher"      : "^7.2",
        "symfony/framework-bundle"      : "^7.2",
        "symfony/routing"               : "^7.2",
        "symfony/config"                : "^7.2",
        "symfony/yaml"                  : "^7.2",
        "symfony/expression-language"   : "^7.2",
        "symfony/security-core"         : "^7.2",
        "symfony/security-http"         : "^7.2",
        "symfony/twig-bridge"           : "^7.2",
        "twig/twig"                     : "^3.0",
        "oasis/logging"                 : "^3.0",
        "oasis/utils"                   : "^3.0",
        "guzzlehttp/guzzle"             : "^7.0"
    },
    "require-dev"      : {
        "phpunit/phpunit"      : "^13.0",
        "symfony/css-selector" : "^7.2",
        "symfony/browser-kit"  : "^7.2",
        "giorgiosironi/eris"   : "^1.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload"         : {
        "psr-4": {
            "Oasis\\Mlib\\Http\\": "src/"
        }
    },
    "autoload-dev"     : {
        "psr-4": {
            "Oasis\\Mlib\\Http\\Test\\": "ut/"
        }
    },
    "bin": [
        "bin/oasis-http-migrate-v3-check"
    ],
    "config": {
        "audit": {
            "block-insecure": false
        }
    }
}
